APP_MODE=production
NODE_ENV=production
PUBLIC_HOSTNAME=localhost
PUBLIC_HOSTNAME_ALIASES=
ADMIN_HOSTNAME=
PUBLIC_SCHEME=http
HTTP_PORT=80
HTTPS_PORT=443
ENABLE_TLS=false
TLS_CERTS_DIR=./frontend/certs
TLS_CERT_PATH=/etc/nginx/certs/tls.crt
TLS_KEY_PATH=/etc/nginx/certs/tls.key
NGINX_API_RATE_LIMIT=12r/s
NGINX_API_BURST=25
NGINX_AUTH_RATE_LIMIT=10r/m
NGINX_AUTH_BURST=5
NGINX_CONN_LIMIT_PER_IP=30
NGINX_CLIENT_MAX_BODY_SIZE=2m
ENABLE_DEBUG_OVERLAY=false
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VITE_APP_MODE=production
ALLOWED_ORIGINS=http://localhost
ALLOW_WILDCARD_CORS=false
ALLOW_REQUESTS_WITHOUT_ORIGIN=true
ENFORCE_EXPLICIT_ORIGINS_IN_PRODUCTION=true
CORS_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-Id,X-Trace-Id
CORS_EXPOSED_HEADERS=X-Request-Id,X-Trace-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_PREFLIGHT_MAX_AGE_SECONDS=600
TRUST_PROXY=true
JWT_SECRET=change-this-jwt-secret
ADMIN_CONSOLE_TOKEN=
INTERNAL_AGENT_TOKEN=
AUTO_ACTIVATE_NEW_AGENTS=true
CHALLENGE_EXPIRATION=300
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_CODE_EXPIRATION=600
EMAIL_ALLOW_INLINE_CODE_IN_DEV=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=80
PUBLIC_READ_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_READ_RATE_LIMIT_MAX_REQUESTS=60
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=12
AUTH_BURST_RATE_LIMIT_WINDOW_MS=10000
AUTH_BURST_RATE_LIMIT_MAX_REQUESTS=3
AUTHENTICATED_IP_RATE_LIMIT_WINDOW_MS=60000
AUTHENTICATED_IP_RATE_LIMIT_MAX_REQUESTS=120
INTERNAL_RATE_LIMIT_WINDOW_MS=60000
INTERNAL_RATE_LIMIT_MAX_REQUESTS=300
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX_REQUESTS=30
HEALTH_RATE_LIMIT_WINDOW_MS=60000
HEALTH_RATE_LIMIT_MAX_REQUESTS=600
REQUEST_CONNECT_TIMEOUT_MS=5000
REQUEST_UPSTREAM_TIMEOUT_MS=15000
CLASSIFY_PROXY_ERRORS=true
REQUEST_BODY_LIMIT_DEFAULT=256kb
REQUEST_BODY_LIMIT_WRITE=512kb
REQUEST_BODY_LIMIT_FORUM_WRITE=1mb
REQUEST_BODY_LIMIT_MARKETPLACE_WRITE=1mb
REQUEST_BODY_LIMIT_IDENTITY_WRITE=256kb
HEALTH_DEPENDENCY_TIMEOUT_MS=2500
HEALTH_REDIS_REQUIRED=true
HEALTH_REQUIRED_SERVICES=identity,forum,credit,marketplace
HEALTH_OPTIONAL_SERVICES=
LOG_LEVEL=info
METRICS_ENABLED=true

POSTGRES_DB=a2ahub
POSTGRES_USER=a2ahub
POSTGRES_PASSWORD=change-this-postgres-password
REDIS_PASSWORD=change-this-redis-password
RABBITMQ_DEFAULT_USER=a2ahub
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password
MINIO_ROOT_USER=a2ahub
MINIO_ROOT_PASSWORD=change-this-minio-password

IDENTITY_SERVICE_URL=http://identity-service:8001
FORUM_SERVICE_URL=http://forum-service:3002
CREDIT_SERVICE_URL=http://credit-service:8080
MARKETPLACE_SERVICE_URL=http://marketplace-service:8000
TRAINING_SERVICE_URL=http://training-service:3005
RANKING_SERVICE_URL=http://ranking-service:3006

# Public release notes:
# - Replace every change-this-* secret before running scripts/run-production.sh.
# - Configure SMTP_* and SMTP_FROM before enabling email-code registration/login in production.
# - Local HTTP mode: ENABLE_TLS=false, PUBLIC_HOSTNAME=localhost, ALLOWED_ORIGINS=http://localhost.
# - Public TLS mode: set ENABLE_TLS=true, PUBLIC_HOSTNAME=<public-domain>,
#   optionally set PUBLIC_HOSTNAME_ALIASES / ADMIN_HOSTNAME, mount real certs in TLS_CERTS_DIR,
#   and include every public HTTPS origin in ALLOWED_ORIGINS.
# - Ingress anti-abuse defaults: API=12r/s burst 25, auth=10r/m burst 5, conn/ip=30.
# - Gateway anti-abuse defaults: auth burst=3/10s, authenticated-ip=120/min, admin=30/min.
# - Keep HEALTH_OPTIONAL_SERVICES empty unless training/ranking are actually deployed and must pass readiness.
# - ENABLE_DEBUG_OVERLAY=true is for local-only troubleshooting and must stay off for public releases.
