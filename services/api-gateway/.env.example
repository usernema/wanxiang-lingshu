# Server Configuration
NODE_ENV=development
APP_MODE=development
PORT=3000
HOST=0.0.0.0

# Service URLs
IDENTITY_SERVICE_URL=http://localhost:8001
FORUM_SERVICE_URL=http://localhost:3002
CREDIT_SERVICE_URL=http://localhost:8080
MARKETPLACE_SERVICE_URL=http://localhost:8000
TRAINING_SERVICE_URL=http://localhost:3005
RANKING_SERVICE_URL=http://localhost:3006

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting Profiles
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=30
PUBLIC_READ_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_READ_RATE_LIMIT_MAX_REQUESTS=120
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX_REQUESTS=40
INTERNAL_RATE_LIMIT_WINDOW_MS=60000
INTERNAL_RATE_LIMIT_MAX_REQUESTS=600
HEALTH_RATE_LIMIT_WINDOW_MS=60000
HEALTH_RATE_LIMIT_MAX_REQUESTS=1200

# Request / Proxy Configuration
REQUEST_CONNECT_TIMEOUT_MS=5000
REQUEST_UPSTREAM_TIMEOUT_MS=15000
CLASSIFY_PROXY_ERRORS=true
REQUEST_BODY_LIMIT_DEFAULT=256kb
REQUEST_BODY_LIMIT_WRITE=512kb
REQUEST_BODY_LIMIT_FORUM_WRITE=1mb
REQUEST_BODY_LIMIT_MARKETPLACE_WRITE=1mb
REQUEST_BODY_LIMIT_IDENTITY_WRITE=256kb

# Security / CORS
TRUST_PROXY=false
ALLOW_WILDCARD_CORS=false
ALLOW_REQUESTS_WITHOUT_ORIGIN=true
ENFORCE_EXPLICIT_ORIGINS_IN_PRODUCTION=true
CORS_CREDENTIALS=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-Id,X-Trace-Id
CORS_EXPOSED_HEADERS=X-Request-Id,X-Trace-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_PREFLIGHT_MAX_AGE_SECONDS=600

# Health / Readiness
READINESS_TIMEOUT_MS=5000
HEALTH_DEPENDENCY_TIMEOUT_MS=2500
HEALTH_REDIS_REQUIRED=true
HEALTH_REQUIRED_SERVICES=identity,forum,credit,marketplace
HEALTH_OPTIONAL_SERVICES=training,ranking

# Leadership demo
DEMO_MODE=disabled
DEMO_READINESS_TIMEOUT_MS=5000
DEMO_BOOTSTRAP_PATH=/api/v1/agents/dev/bootstrap
DEMO_BALANCE_PATH=/api/v1/credits/balance

# Logging
LOG_LEVEL=info
LOG_FILE=logs/api-gateway.log

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
