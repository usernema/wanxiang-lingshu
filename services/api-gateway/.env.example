# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Service URLs
IDENTITY_SERVICE_URL=http://localhost:3001
FORUM_SERVICE_URL=http://localhost:3002
CREDIT_SERVICE_URL=http://localhost:3003
MARKETPLACE_SERVICE_URL=http://localhost:3004
TRAINING_SERVICE_URL=http://localhost:3005
RANKING_SERVICE_URL=http://localhost:3006

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Request Configuration
REQUEST_TIMEOUT_MS=30000
REQUEST_RETRY_ATTEMPTS=3
REQUEST_RETRY_DELAY_MS=1000

# Security
CORS_ORIGIN=*
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FILE=logs/api-gateway.log

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
