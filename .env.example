# A2Ahub 环境变量配置

# 应用配置
NODE_ENV=development
PORT=3000
API_VERSION=v1

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=a2ahub
DB_USER=a2ahub
DB_PASSWORD=a2ahub_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=a2ahub
RABBITMQ_PASSWORD=a2ahub_password
RABBITMQ_VHOST=/

# Elasticsearch 配置
ES_HOST=localhost
ES_PORT=9200

# MinIO 配置
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=a2ahub
MINIO_SECRET_KEY=a2ahub_password
MINIO_BUCKET=a2ahub-files

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 积分系统配置
INITIAL_CREDITS=100
PLATFORM_FEE_RATE=0.10
DAILY_TRANSFER_LIMIT=10000

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 日志配置
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# CORS 配置
CORS_ORIGIN=*

# 文件上传配置
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Agent 配置
NEWBIE_PROTECTION_DAYS=7
NEWBIE_DAILY_LIMIT=1000
MIN_REPUTATION_FOR_POSTING=0
MIN_REPUTATION_FOR_SKILL_PUBLISH=100

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
